# justfile — common tasks for {{cookiecutter.project_name}}
# Run `just` or `just --list` to see all available recipes.

# set up the conda environment, git repo, and pre-commit hooks
bootstrap:
    conda env create -f environment.yml
    git init
    git add .
    git commit -m "feat: initial project structure from template"
    conda run -n {{cookiecutter.package_name}} pre-commit install
    @echo "Done. Activate with: conda activate {{cookiecutter.package_name}}"

# update the lock file after editing environment.yml
lock:
    conda env export --no-builds > environment.lock.yml
    @echo "Lock file updated."

# run the full local quality gate (mirrors CI exactly)
check:
    ruff check .
    ruff format --check .
    mypy src/
    pytest --cov=src/{{cookiecutter.package_name}} --cov-report=term-missing

# auto-fix all ruff issues then format
fix:
    ruff check --fix .
    ruff format .

# run tests only (faster feedback loop during development)
test *args:
    pytest {{"{{"}}args{{"}}"}}

# serve docs locally with live reload
docs:
    mkdocs serve --config-file docs/mkdocs.yml

# create a timestamped run directory and launch a simulation
run config:
    python scripts/run_simulation.py --config configs/{{"{{"}}config{{"}}"}}.toml

# remove all generated outputs (leaves paper/figures intact)
clean:
    find outputs/ -mindepth 1 ! -name '.gitkeep' -delete
    @echo "outputs/ cleared. paper/figures/ left intact."